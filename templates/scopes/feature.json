{
  "schemaVersion": 1,
  "id": "feature/{{FEATURE_NAME}}",
  "type": "feature",
  "name": "{{FEATURE_NAME}}",
  "pipeline": [
    {
      "phase": "research",
      "agent": "researcher",
      "outputCheck": "docs/feature/{{FEATURE_NAME}}/research/*.md"
    },
    {
      "phase": "engineering",
      "agent": "feature-architect",
      "outputCheck": "docs/feature/{{FEATURE_NAME}}/engineering/*.md"
