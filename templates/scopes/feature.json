      ]
    },
    {
      "phase": "implement",
      "agent": null,
      "outputCheck": [
        "docs/feature/{{FEATURE_NAME}}/tasks/task-*/brief.md",
        "docs/feature/{{FEATURE_NAME}}/tasks/task-*/completion.md"
      ]
    }
  ],
  "currentPhase": "research",
  "phaseStatus": "not_started",
  "paths": {
    "researchDir": "docs/feature/{{FEATURE_NAME}}/research/",
    "engineeringDir": "docs/feature/{{FEATURE_NAME}}/engineering/",
    "plan": "docs/feature/{{FEATURE_NAME}}/plan/implementation-plan.md",
    "tasks": "docs/feature/{{FEATURE_NAME}}/tasks/",
    "decisions": "docs/feature/{{FEATURE_NAME}}/decisions.md"
  },
  "history": []
}
